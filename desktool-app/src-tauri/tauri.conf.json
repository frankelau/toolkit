{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toolkit",
  "version": "0.1.0",
  "identifier": "com.liuxianzhao.toolkit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DevKit",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../cc-bridge": "cc-bridge"
    }
  }
}
